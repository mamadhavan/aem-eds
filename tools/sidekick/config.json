{
  "project": "AEM EDS Demo",
  "editUrlLabel": "AEM Editor",
  "editUrlPattern": "{{contentSourceUrl}}{{pathname}}?cmd=open",
  "plugins": [
    {
      "id": "review",
      "title": "Snap Review1...",
      "url": "https://tools.aem.live/tools/snapshot-admin/popover.html",
      "isPopover": true,
      "popoverRect": "width:400px; height:400px",
      "passConfig": true,
      "passReferrer": true,
      "environments": ["preview", "live", "development"]
    },
    {
     "id": "screenshot",
     "title": "Take Screenshot 1",
     "environments": ["preview"],
     "event": "screenshot-trigger"
   }]
}
