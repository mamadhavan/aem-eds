{
  "project": "AEM EDS Demo",
  "editUrlLabel": "AEM Editor",
  "editUrlPattern": "{{contentSourceUrl}}{{pathname}}?cmd=open",
  "plugins": [
    {
      "id": "review",
      "title": "Snap Review",
      "url": "https://tools.aem.live/tools/snapshot-admin/popover.html",
      "isPopover": true,
      "popoverRect": "width:400px; height:400px",
      "passConfig": true,
      "passReferrer": true,
      "environments": ["preview", "live", "development"]
    },
    {
      "id": "puppeteer-audit",
      "title": "Puppeteer Screenshot",
      "containerId": "tools",
      "environments": ["preview", "live", "development"],
      "event": "click",
      "action": "async (el, sk) => { const url = window.location.href; fetch(`http://localhost:8080?url=${url}`).then(() => alert('Running!')).catch(() => alert('Server off')); }"
    },
    {
      "id": "screenshot",
      "title": "📸 Take Screenshot",
      "event": "hello"
    }
  ]
}
