{
  "project": "AEM XWalk Boilerplate",
  "editUrlLabel": "AEM Editor",
  "editUrlPattern": "{{contentSourceUrl}}{{pathname}}?cmd=open",
  "plugins": [
    {
      "id": "review",
      "title": "Review...",
      "environments": [
        "dev",
        "preview",
        "review"
      ],
      "url": "https://tools.aem.live/tools/snapshot-admin/popover.html",
      "isPopover": true,
      "popoverRect": "width:400px; height:400px",
      "passConfig": true,
      "passReferrer": true
    }
}
